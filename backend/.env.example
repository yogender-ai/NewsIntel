# Database/cache
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/newsintel
REDIS_URL=

# Gateway for Hugging Face Space, OpenRouter, and Gemini proxy calls
GATEWAY_BASE_URL=https://cloud-command.onrender.com/api/gateway
GATEWAY_SECRET=replace_with_gateway_secret
HF_SPACE_URL=YAsh213kadian/News_intel_HF_space_1
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Admin/ingestion protection
ADMIN_SECRET=replace_with_admin_secret
INGEST_SECRET=replace_with_ingest_secret
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:5173

# Ingestion worker
WORKER_MODE=scheduler
INGEST_TOPICS=ai,tech,markets
INGEST_REGIONS=global
INGEST_MAX_ARTICLES=40

# Email alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=NewsIntel Alerts <your_email@gmail.com>
